# Secrets — never commit real keys; use .env.example as the template.
# Also enforced by scripts/git-hooks/pre-commit (see CLAUDE.md → Secrets).
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
id_rsa
id_ed25519
credentials

# Python
.venv/
__pycache__/
*.pyc
uv.lock

# Generated artifacts (videos, images, audio, state)
output/

# Local music library (drop royalty-free mp3s here)
music/

# macOS
.DS_Store

.idea
venv/

