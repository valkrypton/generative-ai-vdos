# Copy to .env and fill in — the pipeline auto-loads it (empty values are ignored).

# Required — LLM for the shot-plan stage:
OPENAI_API_KEY=""

# Required for real images (qwen, free quota) + animation (Wan).
# Sign up: modelstudio.console.alibabacloud.com — pick the SINGAPORE region
# (new accounts get free image quota + ~1650s of video credit for 90 days).
DASHSCOPE_API_KEY=""
# Optional — workspace endpoint; leave empty to use the default intl endpoint:
DASHSCOPE_API_URL=""

# Optional — free company LiteLLM proxy for shot plans (preferred when set):
# LITELLM_API_KEY=""       # picks groq/llama-3.3-70b-versatile by default
# LITELLM_BASE_URL=""      # default: https://litellm.arbisoft.com
# LITELLM_MODEL=""         # override the proxy model id

# Optional alternatives (not needed for the standard setup):
# ANTHROPIC_API_KEY=""     # Claude instead of OpenAI for shot plans
# REPLICATE_API_TOKEN=""   # Flux images (also: pip install replicate)
# PEXELS_API_KEY=""        # free stock photos instead of AI images

# Feature flags — set these once instead of passing CLI params (1/true/yes/on):
# AUTO_APPROVE=""          # skip the shot-plan review gate (= --approve)
# ANIMATE=""               # animate stills into clips — SPENDS Wan credit (= --animate)
# IMAGE_BACKEND=""         # force image provider: flux-schnell, gpt-image-1, pexels, placeholder
# VIDEO_BACKEND=""         # force video provider: wan-i2v (implies ANIMATE)
# NARRATOR_VOICE=""        # edge-tts narrator voice, e.g. en-US-AndrewNeural
