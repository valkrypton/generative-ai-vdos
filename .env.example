# Copy to .env and fill in. Load into your shell with:
#   set -a && source .env && set +a

# LLM for the shot-plan stage — set at least one:
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Image backends (optional — first available wins, placeholder used if none):
REPLICATE_API_TOKEN=""
PEXELS_API_KEY=""

# Video backend (optional — animates scene stills into clips with --animate):
# Wan via Alibaba Model Studio; new intl accounts get ~1650s free video credit.
# Sign up: modelstudio.console.alibabacloud.com (Singapore region)
DASHSCOPE_API_KEY=""
# Optional workspace endpoint (defaults to the intl endpoint):
# DASHSCOPE_API_URL=""
